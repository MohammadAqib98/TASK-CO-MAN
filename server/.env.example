# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=your_jwt_super_secret_session_key_change_me_in_production

# Database
# If running MongoDB locally (standard connection):
DATABASE_URL=mongodb://127.0.0.1:27017/taskmanager

# If using MongoDB Atlas cloud cluster, replace with your connection string:
# DATABASE_URL=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/taskmanager?retryWrites=true&w=majority

# CORS (Frontend URL)
CLIENT_URL=http://localhost:5173
